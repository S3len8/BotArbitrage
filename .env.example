# Скопируй в .env и заполни ключи

# ---- PostgreSQL ----
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/arb_bot

LEVERAGE=5
MIN_SPREAD_PCT=0.5
MAX_OPEN_POSITIONS=3
BALANCE_ALERT_PCT=50

TG_API_ID=12345678
TG_API_HASH=your_hash
TG_SESSION=arb_bot_session
SIGNAL_CHANNEL=@channel_name

NOTIFY_BOT_TOKEN=bot_token
NOTIFY_CHAT_ID=your_chat_id

BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
MEXC_API_KEY=
MEXC_API_SECRET=
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=
GATE_API_KEY=
GATE_API_SECRET=
OURBIT_API_KEY=
OURBIT_API_SECRET=
